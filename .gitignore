# Ignore Visual Studio Code settings
.vscode/

# Ignore MacOS system files
.DS_Store

# ESP-IDF build output
/build/

# ESP-IDF component manager downloads (regenerated from idf_component.yml)
managed_components/

# ESP-IDF generated files
/sdkconfig
/sdkconfig.old

# Local clangd configuration generated by ESP-IDF tooling
/.clangd

# Compiled host-test binaries (built by `make -C components/*/host_test test`)
components/*/host_test/test_*
!components/*/host_test/test_*.c
components/*/host_test/*.dSYM/

# Agent files
/AGENTS.md
